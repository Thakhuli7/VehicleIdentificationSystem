<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.vehicleidentificationsystem.VehicleManagementController"
      style="-fx-background-color: #f5f7fa;">

    <padding>
        <Insets top="25" right="30" bottom="25" left="30"/>
    </padding>

    <!-- Header -->
    <VBox spacing="5">
        <Label text="🚗 VEHICLE MANAGEMENT"
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <Label text="Register, update, and track all vehicles"
               style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>
        <Separator style="-fx-background-color: #3498db; -fx-pref-height: 3;"/>
    </VBox>

    <!-- Search -->
    <HBox spacing="10">
        <TextField fx:id="searchField" promptText="Search by registration, make, or model..."
                   style="-fx-pref-width: 300; -fx-padding: 10; -fx-background-radius: 5;"/>
        <ComboBox fx:id="filterCombo" promptText="Filter by status" prefWidth="150"/>
        <Button text="🔍 Search" onAction="#searchVehicles"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 10 20; -fx-background-radius: 5;"/>
        <Button text="➕ Add Vehicle" onAction="#showAddDialog"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 10 20; -fx-background-radius: 5;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="📥 Export" onAction="#exportVehicles"
                style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-padding: 10 20; -fx-background-radius: 5;"/>
    </HBox>

    <!-- Statistics -->
    <HBox spacing="15">
        <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 10 20;">
            <Label text="Total Vehicles" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
            <Label fx:id="totalVehiclesCard" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
        </VBox>
        <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 10 20;">
            <Label text="Active" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
            <Label fx:id="activeVehiclesCard" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
        </VBox>
        <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 10 20;">
            <Label text="Needs Service" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
            <Label fx:id="needsServiceCard" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #e67e22;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- Vehicle Table -->
    <TableView fx:id="vehicleTable" prefHeight="350">
        <columns>
            <TableColumn fx:id="colVehicleId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colRegistration" text="Registration" prefWidth="120"/>
            <TableColumn fx:id="colMake" text="Make" prefWidth="100"/>
            <TableColumn fx:id="colModel" text="Model" prefWidth="100"/>
            <TableColumn fx:id="colYear" text="Year" prefWidth="60"/>
            <TableColumn fx:id="colColor" text="Color" prefWidth="80"/>
            <TableColumn fx:id="colMileage" text="Mileage" prefWidth="80"/>
            <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
        </columns>
    </TableView>

    <!-- Action Buttons -->
    <HBox spacing="10" alignment="CENTER">
        <Button text="✏️ Edit Selected" onAction="#editVehicle"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 8 20; -fx-background-radius: 5;"/>
        <Button text="🗑️ Delete Selected" onAction="#deleteVehicle"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-padding: 8 20; -fx-background-radius: 5;"/>
        <Button text="🔧 Service History" onAction="#viewServiceHistory"
                style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-padding: 8 20; -fx-background-radius: 5;"/>
        <Button text="📋 Insurance" onAction="#viewInsurance"
                style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-padding: 8 20; -fx-background-radius: 5;"/>
        <Button text="👮 Police Records" onAction="#viewPoliceRecords"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-padding: 8 20; -fx-background-radius: 5;"/>
    </HBox>

    <!-- Status Bar -->
    <HBox style="-fx-background-color: #2c3e50; -fx-background-radius: 5; -fx-padding: 8 15;">
        <Label fx:id="statusLabel" text="Ready" style="-fx-text-fill: white;"/>
    </HBox>

</VBox>