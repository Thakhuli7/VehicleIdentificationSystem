<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.vehicleidentificationsystem.InsuranceTrackingController"
      style="-fx-background-color: #f5f7fa;">

    <padding>
        <Insets top="25" right="30" bottom="25" left="30"/>
    </padding>

    <!-- Header -->
    <VBox spacing="5">
        <Label text="📋 INSURANCE TRACKING"
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <Label text="Manage insurance policies and claims"
               style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>
        <Separator style="-fx-background-color: #3498db; -fx-pref-height: 3;"/>
    </VBox>

    <!-- Tab Pane for Policies and Claims -->
    <TabPane>
        <Tab text="Insurance Policies" closable="false">
            <VBox spacing="10" style="-fx-padding: 15;">
                <HBox spacing="10">
                    <TextField fx:id="policySearchField" promptText="Search by policy number or vehicle..."
                               style="-fx-pref-width: 250; -fx-padding: 10;"/>
                    <Button text="🔍 Search" onAction="#searchPolicies"
                            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 10 20;"/>
                    <Button text="➕ Add Policy" onAction="#showAddPolicyDialog"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 10 20;"/>
                </HBox>

                <TableView fx:id="policyTable" prefHeight="350">
                    <columns>
                        <TableColumn fx:id="colPolicyId" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colVehicleReg" text="Vehicle Reg" prefWidth="100"/>
                        <TableColumn fx:id="colCompany" text="Insurance Company" prefWidth="150"/>
                        <TableColumn fx:id="colPolicyNumber" text="Policy Number" prefWidth="120"/>
                        <TableColumn fx:id="colStartDate" text="Start Date" prefWidth="100"/>
                        <TableColumn fx:id="colEndDate" text="End Date" prefWidth="100"/>
                        <TableColumn fx:id="colPremium" text="Premium" prefWidth="80"/>
                        <TableColumn fx:id="colPolicyStatus" text="Status" prefWidth="80"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>

        <Tab text="Claims" closable="false">
            <VBox spacing="10" style="-fx-padding: 15;">
                <HBox spacing="10">
                    <TextField fx:id="claimSearchField" promptText="Search claims..."
                               style="-fx-pref-width: 250; -fx-padding: 10;"/>
                    <Button text="🔍 Search" onAction="#searchClaims"
                            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 10 20;"/>
                    <Button text="➕ Add Claim" onAction="#showAddClaimDialog"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 10 20;"/>
                </HBox>

                <TableView fx:id="claimTable" prefHeight="350">
                    <columns>
                        <TableColumn fx:id="colClaimId" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colPolicyNum" text="Policy Number" prefWidth="120"/>
                        <TableColumn fx:id="colClaimDate" text="Claim Date" prefWidth="100"/>
                        <TableColumn fx:id="colClaimAmount" text="Claim Amount" prefWidth="100"/>
                        <TableColumn fx:id="colApprovedAmount" text="Approved" prefWidth="100"/>
                        <TableColumn fx:id="colClaimStatus" text="Status" prefWidth="100"/>
                        <TableColumn fx:id="colClaimType" text="Type" prefWidth="120"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>
    </TabPane>

    <!-- Expiry Alerts -->
    <VBox spacing="5">
        <Label text="⚠️ Insurance Expiring Soon (Next 30 Days)" style="-fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
        <ListView fx:id="expiryListView" prefHeight="100"/>
    </VBox>

    <!-- Status Bar -->
    <HBox style="-fx-background-color: #2c3e50; -fx-background-radius: 5; -fx-padding: 8 15;">
        <Label fx:id="statusLabel" text="Ready" style="-fx-text-fill: white;"/>
    </HBox>

</VBox>