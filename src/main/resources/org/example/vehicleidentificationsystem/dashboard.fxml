<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.vehicleidentificationsystem.DashboardController"
      alignment="TOP_CENTER" prefWidth="1100" prefHeight="750"
      style="-fx-background-color: linear-gradient(to bottom right, #f0f2f5, #e8ecf1);">

    <padding>
        <Insets top="15" right="20" bottom="15" left="20"/>
    </padding>

    <!-- ========== LIGHT COLORED MENU BAR WITH EMOJIS ========== -->
    <MenuBar style="-fx-background-color: #ecf0f1; -fx-border-color: #bdc3c7; -fx-border-width: 0 0 1 0;">
        <menus>
            <!-- FILE MENU - LIGHT BLUE -->
            <Menu text="📁 FILE" style="-fx-text-fill: #2980b9; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-color: #d6eaf8;">
                <items>
                    <MenuItem fx:id="exitMenuItem" text="🚪 Exit" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold;"/>
                </items>
            </Menu>

            <!-- MODULES MENU - LIGHT GREEN -->
            <Menu text="⚙️ MODULES" style="-fx-text-fill: #27ae60; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-color: #d5f5e3;">
                <items>
                    <MenuItem fx:id="customerMenuItem" text="👥 Customer Management" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold;"/>
                    <MenuItem fx:id="vehicleMenuItem" text="🚗 Vehicle Management" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold;"/>
                    <MenuItem fx:id="workshopMenuItem" text="🔧 Workshop Services" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold;"/>
                    <MenuItem fx:id="insuranceMenuItem" text="📋 Insurance Tracking" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold;"/>
                    <MenuItem fx:id="policeMenuItem" text="👮 Police Records" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold;"/>
                    <SeparatorMenuItem/>
                    <MenuItem fx:id="reportsMenuItem" text="📊 Generate Reports" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold;"/>
                </items>
            </Menu>

            <!-- HELP MENU - LIGHT ORANGE -->
            <Menu text="❓ HELP" style="-fx-text-fill: #e67e22; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-color: #fdebd0;">
                <items>
                    <MenuItem fx:id="aboutMenuItem" text="ℹ️ About" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold;"/>
                </items>
            </Menu>
        </menus>
    </MenuBar>

    <!-- ========== HEADER ========== -->
    <VBox spacing="5">
        <Label text="🚗 VEHICLE IDENTIFICATION SYSTEM"
               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <Label text="📊 Manage and Track Vehicle Information in Real-Time"
               style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>
        <Separator style="-fx-background-color: #3498db; -fx-pref-height: 3;"/>
    </VBox>

    <!-- ========== CONTROL PANEL ========== -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <Button fx:id="loadButton" text="🔄 LOAD SYSTEM DATA"
                style="-fx-background-color: linear-gradient(to bottom, #3498db, #2980b9); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 25;"/>
        <Button fx:id="refreshButton" text="♻️ REFRESH"
                style="-fx-background-color: linear-gradient(to bottom, #27ae60, #1e8449); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 25;"/>
        <Button fx:id="exportButton" text="📥 EXPORT"
                style="-fx-background-color: linear-gradient(to bottom, #e67e22, #d35400); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 25;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <ProgressIndicator fx:id="progressIndicator" visible="false" prefWidth="25" prefHeight="25"/>
            <ProgressBar fx:id="progressBar" visible="false" prefWidth="200" prefHeight="8"/>
        </HBox>
    </HBox>

    <!-- ========== STATISTICS CARDS ========== -->
    <HBox spacing="15">
        <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <Label text="🚗 TOTAL VEHICLES" style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;"/>
            <Label fx:id="totalVehiclesLabel" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
        </VBox>
        <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <Label text="⭐ NEW VEHICLES" style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;"/>
            <Label fx:id="newVehiclesLabel" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
        </VBox>
        <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <Label text="📋 ACTIVE INSURANCE" style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;"/>
            <Label fx:id="insuranceLabel" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #e67e22;"/>
        </VBox>
    </HBox>

    <!-- ========== TABLE AND SCROLLPANE ========== -->
    <HBox spacing="20">

        <!-- LEFT: TABLE -->
        <VBox spacing="10" HBox.hgrow="ALWAYS">
            <Label text="📋 VEHICLE REGISTRATION RECORDS" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

            <TableView fx:id="vehicleTable" prefHeight="350"
                       style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);">
                <columns>
                    <TableColumn fx:id="colVehicleId" text="🆔 ID" prefWidth="50"/>
                    <TableColumn fx:id="colRegistrationNo" text="📝 REGISTRATION" prefWidth="130"/>
                    <TableColumn fx:id="colMake" text="🏭 MAKE" prefWidth="110"/>
                    <TableColumn fx:id="colModel" text="🚙 MODEL" prefWidth="110"/>
                    <TableColumn fx:id="colYear" text="📅 YEAR" prefWidth="70"/>
                    <TableColumn fx:id="colStatus" text="✅ STATUS" prefWidth="100"/>
                </columns>
            </TableView>

            <!-- PAGINATION -->
            <Pagination fx:id="pagination" style="-fx-background-color: transparent; -fx-padding: 10 0;"/>
        </VBox>

        <!-- RIGHT: SCROLLPANE -->
        <VBox spacing="10" prefWidth="280">
            <Label text="📋 QUICK VEHICLE LIST" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

            <ScrollPane fx:id="vehicleScrollPane" prefHeight="350"
                        style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);"
                        fitToWidth="true">
                <content>
                    <VBox spacing="8" style="-fx-padding: 12;">
                        <Label text="🚗 Vehicle 1 - Toyota Camry" style="-fx-padding: 8 12; -fx-background-color: #f8f9fa; -fx-background-radius: 8;"/>
                        <Label text="🚙 Vehicle 2 - Honda Civic" style="-fx-padding: 8 12; -fx-background-color: #f8f9fa; -fx-background-radius: 8;"/>
                        <Label text="🚘 Vehicle 3 - Ford Mustang" style="-fx-padding: 8 12; -fx-background-color: #f8f9fa; -fx-background-radius: 8;"/>
                        <Label text="🚖 Vehicle 4 - BMW X5" style="-fx-padding: 8 12; -fx-background-color: #f8f9fa; -fx-background-radius: 8;"/>
                        <Label text="🚗 Vehicle 5 - Mercedes C-Class" style="-fx-padding: 8 12; -fx-background-color: #f8f9fa; -fx-background-radius: 8;"/>
                        <Label text="🚙 Vehicle 6 - Audi A4" style="-fx-padding: 8 12; -fx-background-color: #f8f9fa; -fx-background-radius: 8;"/>
                        <Label text="🚘 Vehicle 7 - Tesla Model 3" style="-fx-padding: 8 12; -fx-background-color: #f8f9fa; -fx-background-radius: 8;"/>
                        <Label text="🚖 Vehicle 8 - Hyundai Elantra" style="-fx-padding: 8 12; -fx-background-color: #f8f9fa; -fx-background-radius: 8;"/>
                        <Label text="🚗 Vehicle 9 - Kia Sportage" style="-fx-padding: 8 12; -fx-background-color: #f8f9fa; -fx-background-radius: 8;"/>
                        <Label text="🚙 Vehicle 10 - Nissan Altima" style="-fx-padding: 8 12; -fx-background-color: #f8f9fa; -fx-background-radius: 8;"/>
                        <Label text="🚘 Vehicle 11 - Chevrolet Malibu" style="-fx-padding: 8 12; -fx-background-color: #f8f9fa; -fx-background-radius: 8;"/>
                        <Label text="🚖 Vehicle 12 - Volkswagen Jetta" style="-fx-padding: 8 12; -fx-background-color: #f8f9fa; -fx-background-radius: 8;"/>
                        <Label text="🚗 Vehicle 13 - Subaru Outback" style="-fx-padding: 8 12; -fx-background-color: #f8f9fa; -fx-background-radius: 8;"/>
                        <Label text="🚙 Vehicle 14 - Mazda CX-5" style="-fx-padding: 8 12; -fx-background-color: #f8f9fa; -fx-background-radius: 8;"/>
                        <Label text="🚘 Vehicle 15 - Lexus RX" style="-fx-padding: 8 12; -fx-background-color: #f8f9fa; -fx-background-radius: 8;"/>
                        <Label text="🚖 Vehicle 16 - Jeep Grand Cherokee" style="-fx-padding: 8 12; -fx-background-color: #f8f9fa; -fx-background-radius: 8;"/>
                        <Label text="🚗 Vehicle 17 - Dodge Charger" style="-fx-padding: 8 12; -fx-background-color: #f8f9fa; -fx-background-radius: 8;"/>
                        <Label text="🚙 Vehicle 18 - Ford Explorer" style="-fx-padding: 8 12; -fx-background-color: #f8f9fa; -fx-background-radius: 8;"/>
                        <Label text="🚘 Vehicle 19 - Toyota RAV4" style="-fx-padding: 8 12; -fx-background-color: #f8f9fa; -fx-background-radius: 8;"/>
                        <Label text="🚖 Vehicle 20 - Honda CR-V" style="-fx-padding: 8 12; -fx-background-color: #f8f9fa; -fx-background-radius: 8;"/>
                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </HBox>

    <!-- ========== STATUS BAR ========== -->
    <HBox style="-fx-background-color: #2c3e50; -fx-background-radius: 8; -fx-padding: 10 20;">
        <Label fx:id="statusLabel" text="✅ Ready" style="-fx-text-fill: #ecf0f1; -fx-font-size: 12px;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="🔐 Secure SSL Connection" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
        <Label text="●" style="-fx-text-fill: #27ae60; -fx-font-size: 10px; -fx-padding: 0 8 0 8;"/>
        <Label text="🐘 PostgreSQL Active" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
        <Label text="●" style="-fx-text-fill: #27ae60; -fx-font-size: 10px; -fx-padding: 0 8 0 8;"/>
        <Label text="🟢 Real-time Sync" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
    </HBox>

</VBox>